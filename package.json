{
  "name": "selenium-mocha-digital-skola",
  "version": "1.0.0",
  "description": "Selenium webdriver test using mocha with Mochawesome report",
  "scripts": {
    "login": "mocha test/spec --recursive --timeout 60000 --reporter mochawesome",
    "test": "mocha tests/specs/login.test.js --timeout 60000",
    "screenshot": "mocha tests/specs/login_ss.test.js --timeout 60000",
    "visual": "mocha tests/specs/visual.test.js --timeout 60000"
  },
  "dependencies": {
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "selenium-webdriver": "^4.43.0"
  },
  "devDependencies": {
    "mocha": "^10.4.0",
    "mocha-simple-html-reporter": "^2.0.0",
    "mochawesome": "^7.1.3"
  }
}
